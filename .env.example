# =============================================================================
# .env.example — TEMPLATE. Do NOT put real secrets in this file.
#
# Setup:
#   1. cp .env.example .env
#   2. Fill in every <REPLACE_ME...> value below.
#   3. The .env file is gitignored — never commit it.
#
# For local Docker, use the helper:
#   make init-env       (generates secure Airflow keys and seeds a dev .env)
# =============================================================================

# ---------- Postgres warehouse ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=analytics
# Required. Local dev: any non-empty string. Prod: pull from a secret manager.
POSTGRES_PASSWORD=<REPLACE_ME_strong_random_password>

# ---------- dbt ----------
# 'dev' targets local postgres; 'prod' targets snowflake (see profiles.yml)
DBT_PROFILE_TARGET=dev
DBT_THREADS=4

# Snowflake (only used when DBT_PROFILE_TARGET=prod)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ANALYTICS
SNOWFLAKE_SCHEMA=DBT

# ---------- Airflow ----------
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Required. Generate a fresh one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=<REPLACE_ME_run_fernet_generate_key>

# Required. Any sufficiently random 32+ char string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=<REPLACE_ME_random_32_char_string>

AIRFLOW_ADMIN_USER=admin
# Required. NEVER leave as 'admin' — even on local Docker.
AIRFLOW_ADMIN_PASSWORD=<REPLACE_ME_strong_password>

# ---------- Ingestion ----------
INGEST_BACKEND=python_local
SEED_NUM_CUSTOMERS=2000
SEED_NUM_PRODUCTS=300
SEED_NUM_ORDERS=15000
SEED_NUM_SESSIONS=40000
SEED_RANDOM_STATE=42

# ---------- Metabase ----------
MB_DB_TYPE=h2
MB_SITE_NAME=Ecommerce Analytics
